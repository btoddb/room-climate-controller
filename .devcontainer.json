{
    "name": "btoddb/room-climate-controller",
    "image": "mcr.microsoft.com/devcontainers/base:debian",
    "postCreateCommand": {
        "setup": "scripts/setup && npm --prefix custom_components/room_climate_controller/card install",
        "hassfest-alias": "echo 'alias hassfest=\"docker run --rm -v \\$(pwd):/github/workspace ghcr.io/home-assistant/hassfest:latest\"' >> ~/.zshrc"
    },
    "forwardPorts": [
        8123
    ],
    "portsAttributes": {
        "8123": {
            "label": "Home Assistant",
            "onAutoForward": "notify"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "anthropic.claude-code",
                "charliermarsh.ruff",
                "github.vscode-pull-request-github",
                "ms-azuretools.vscode-containers",
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ryanluker.vscode-coverage-gutters",
                "streetsidesoftware.code-spell-checker",
                "redhat.vscode-yaml"
            ],
            "settings": {
                "files.eol": "\n",
                "editor.tabSize": 4,
                "editor.formatOnPaste": true,
                "editor.formatOnSave": true,
                "editor.formatOnType": false,
                "files.trimTrailingWhitespace": true,
                "python.analysis.typeCheckingMode": "basic",
                "python.analysis.autoImportCompletions": true,
                "[python]": {
                    "editor.defaultFormatter": "charliermarsh.ruff"
                }
            }
        }
    },
    "remoteUser": "vscode",
    "features": {
        "ghcr.io/devcontainers/features/node:2.0.0": {
            "version": "20"
        },
        "ghcr.io/devcontainers/features/python:1": {
            // minimum for room-climate-controller is 3.13, but using 3.14 for development
            "version": "3.14"
        },
        "ghcr.io/devcontainers-extra/features/apt-packages:1": {
            // moreutils provides sponge
            "packages": "ffmpeg,libturbojpeg0,libpcap-dev,moreutils,git-delta"
        },
        "ghcr.io/devcontainers/features/common-utils:2": {
            // common-utils provides base commands (curl, net-tools, jq, unzip, etc)
            "installZsh": "true",
            "configureZshAsDefaultShell": "true"
        },
        "ghcr.io/devcontainers/features/docker-in-docker:3.0.1": {
            // moby packages aren't published for Debian trixie; use upstream Docker CE
            "moby": false
        }
    },
    "remoteEnv": {
        "SSH_AUTH_SOCK": "/ssh-agent.sock"
    },
    "mounts": [
        "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind"
    ]
}